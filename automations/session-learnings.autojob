# Daily session-learnings -- the intelligence pass over source #2 (sessions).
# Runs after session-capture (03:00) has flattened yesterday's transcripts into
# brain-db/raw/sessions/. Distills operating rules + anti-patterns into the wiki
# and emits the report-only CLAUDE.md digest. The canonical prompt lives in
# ingest/session-learnings.prompt.md so it stays reviewable/versioned in one place.
LABEL=com.cyb.session-learnings
SCHEDULE=03:30
RUNTIME=claude
MODEL=claude-fable-5
COMMAND=Read ingest/session-learnings.prompt.md and execute it exactly as written. BRAIN_DB is ~/Claude/brain-db.
WORKDIR=.
