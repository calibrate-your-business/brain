# Daily session-capture -- brain source #2. Flattens this machine's Claude Code
# session transcripts (~/.claude/projects) into immutable raw markdown under
# brain-db/raw/sessions/<host>/. Mechanics only (no AI); brain-ingest distills.
# Runs at 03:00, an hour before session-learnings (04:00), so the pass always
# reads a fresh delta. Discovered by the standalone automations manager.
LABEL=com.cyb.session-capture
SCHEDULE=03:00
RUNTIME=script
COMMAND=python3 ingest/capture_sessions.py
WORKDIR=.
